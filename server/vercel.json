{
    "version":2,
    "builds":[
        {
            "src":"server/server.js",
            "use":"@vercel/node",
            "config": {
               "includesFiles":[
                "dist/**"
               ]            }
        }
    ],
    "routes":[
        {
            "src":"/(.*)",
            "dest":"/server/server.js"
        }
    ]
}